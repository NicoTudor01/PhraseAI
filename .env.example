# AGENT5: [CHANGE] Reference only. Copy frontend values to frontend/.env and backend values to backend/.env.

# Frontend
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_FORCE_LOGIN_ON_VISIT=false

# Backend
ANTHROPIC_API_KEY=your-provider-key
ANTHROPIC_BASE_URL=
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=1200
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FRONTEND_ORIGIN=http://localhost:5173

# Optional provider resilience and privacy limits
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_FALLBACK_MODELS=meta-llama/llama-3.1-8b-instruct:free,openrouter/auto
OPENROUTER_TIMEOUT_SECONDS=25
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=PhraseAI
ENABLE_LOCAL_REWRITE_FALLBACK=true
MAX_DRAFT_CHARS=12000
MAX_CONTEXT_CHARS=8000
MAX_FINAL_CHARS=12000
MAX_PROFILE_JSON_CHARS=24000
ALLOW_DEV_STRESS_TEST=false
